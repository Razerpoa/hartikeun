# ============================================
# Hartikeun — Environment Configuration
# ============================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# Then run: docker compose up -d
# ============================================

# --- Required ---
# Your Google Gemini API key
GEMINI_API_KEY="your-gemini-api-key-here"

# --- Server ---
# Port the container listens on (default: 3000)
# PORT=3000

# --- Optional Overrides ---
# Gemini model name (default: gemini-3.1-flash-lite)
# GEMINI_MODEL=gemini-3.1-flash-lite

# CORS origin (default: *, allow all)
# CORS_ORIGIN=*

# --- Cache ---
# Max entries in LRU cache (default: 1000)
# LRU_MAX=1000

# Cache TTL in milliseconds (default: 86400000 = 24h)
# LRU_TTL_MS=86400000

# --- Rate Limiting ---
# Rate limit window in milliseconds (default: 60000 = 1 min)
# RATE_LIMIT_WINDOW_MS=60000

# Max requests per window per IP (default: 30)
# RATE_LIMIT_MAX=30

# --- Request Timeout ---
# Gemini API timeout in milliseconds (default: 30000 = 30s)
# REQUEST_TIMEOUT_MS=30000
